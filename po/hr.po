#: data/parlatype.desktop.in:4 data/parlatype.metainfo.xml.in:8
#: src/pt-app.c:196 src/resources/window.ui:30
msgid "Parlatype"
msgstr "Parlatype"

#: data/parlatype.desktop.in:5
msgid "Transcription utility"
msgstr "Uslužni program za transkripciju"

#: data/parlatype.desktop.in:6
msgid "Transcription;"
msgstr "Transkripcija;"

#: data/parlatype.metainfo.xml.in:9
msgid "Media player for transcription"
msgstr "Media player za transkripciju"

#: data/parlatype.metainfo.xml.in:12
msgid ""
"Parlatype is an easy to use media player. Its main purpose is to help you "
"transcribing speech."
msgstr ""
"Parlatype je jednostavan media player. Njegova je glavna svrha pomoći pri "
"transkripciji govora."

#: data/parlatype.metainfo.xml.in:19
msgid "Main window"
msgstr "Glavni prozor"

#: data/parlatype.metainfo.xml.in:28
msgid "Gabor Karsay"
msgstr "Gabor Karsay"

#: data/parlatype.metainfo.xml.in:47
msgid "Website moved to www.parlatype.xyz."
msgstr "Web-stranica je premještena na www.parlatype.xyz."

#: data/parlatype.metainfo.xml.in:48
msgid "App ID changed accordingly."
msgstr "App ID se promijenio u skladu s tim."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:49 data/parlatype.metainfo.xml.in:60
#: data/parlatype.metainfo.xml.in:81 data/parlatype.metainfo.xml.in:93
#: data/parlatype.metainfo.xml.in:109
msgid "Translation updates for several languages."
msgstr "Aktualizirani prijevodi za nekoliko jezika."

#: data/parlatype.metainfo.xml.in:56
msgid ""
"Follow GNOME human interface guidelines throughout the app using libadwaita."
msgstr ""
"Slijedi GNOME smjernice za ljudsko sučelje kroz cijelu aplikaciju koristeći "
"libadwaita."

#: data/parlatype.metainfo.xml.in:57
msgid "Add a theme selector (borrowed from GNOME Text Editor)."
msgstr "Dodan selektor teme (posuđen iz GNOME Text Editora)."

#: data/parlatype.metainfo.xml.in:58
msgid "Fix F10 shortcut to toggle main menu."
msgstr "Ispravljen prečac F10 za uključivanje/isključivanje glavnog izbornika."

#: data/parlatype.metainfo.xml.in:59
msgid ""
"Remove support for Mozilla DeepSpeech because the project is discontinued."
msgstr "Uklonjena podrška za Mozilla DeepSpeech jer je projekt obustavljen."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:67
msgid ""
"This release is switching to GTK 4 and brings translation updates for "
"several languages."
msgstr ""
"Ovo izdanje prelazi na GTK 4 i sadržava aktulizirane prijevode za nekoliko "
"jezika."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:73
msgid "This is a minor release with a new feature."
msgstr "Ovo je manje izdanje s novom funkcijom."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:76
msgid "Added MPRIS interface."
msgstr "Dodano je MPRIS sučelje."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:78
msgid "Smaller bug fixes."
msgstr "Ispravci manjih grešaka."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:80
msgid "Switched to Weblate for translations."
msgstr "Prijelaz na prevodilačku platformu „Weblate“."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:87 data/parlatype.metainfo.xml.in:116
msgid "This is a major release with new features."
msgstr "Ovo je glavno izdanje s novim funkcijama."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:90
msgid "Support for Mozilla DeepSpeech."
msgstr "Podrška za Mozilla DeepSpeech."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:92
msgid "New configuration system for Automatic Speech Recognition."
msgstr "Novi konfiguracijski sustav za automatsko prepoznavanje govora."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:100
msgid "This is a minor release with bug fixes and minor new features."
msgstr "Ovo je manje izdanje s ispracima grešaka i nekih novih funkcija."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:103
msgid ""
"Mute/unmute volume by clicking on the volume icon with the pointer’s "
"secondary button (usually right mouse button)."
msgstr ""
"Isključi ili uključi zvuk klikom na ikonu glasnoće sekundarnim gumbom "
"kursora (obično desni gumb miša)."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:105
msgid ""
"With Pulseaudio Parlatype doesn’t change the system volume anymore, just its "
"own application specific volume."
msgstr ""
"Uz PulseAudio, Parlatype više ne mijenja glasnoću sustava, već samo "
"specifičnu glasnoću vlastite aplikacije."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:107
msgid "The initial volume level is picked up from Pulseaudio."
msgstr "Početna razina glasnoće se preuzima od Pulseaudio."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:119
msgid "Waveform is loaded on-the-fly, there is no blocking progress dialog."
msgstr ""
"Valni oblik zvuka se učitava odmah, bez blokirajućeg dijaloga za napredak."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:121
msgid "Waveform can be changed continuously instead of in discrete steps."
msgstr ""
"Valni oblik zvuka se može mijenjati kontinuirano umjesto u diskretnim "
"koracima."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:128
msgid "This is a minor release."
msgstr "Ovo je manje izdanje."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:131
msgid ""
"Update time label only if time has changed. This is a performance increase, "
"cursor movement should be smoother on slower systems."
msgstr ""
"Aktualiziraj oznaku vremena samo ako se je vrijeme promijenilo. Ovo je "
"poboljšanje performanse, kretanje kursora trebalo bi biti glađe na sporijim "
"sustavima."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:133
msgid "Translation updates for Hungarian, Lithuanian and Spanish"
msgstr "Aktualizirani prijevodi za mađarski, litvanski i španjolski"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:140
msgid "This is a minor release with some changes."
msgstr "Ovo je manje izdanje s nekim promjenama."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:143
msgid ""
"Automatic speech recognition (ASR) is now disabled by default and it’s only "
"shown, if Parlatype is launched with the new parameter \\\"--with-asr\\\""
msgstr ""
"Automatsko prepoznavanje govora (ASR) je sada standardno deaktivirano i "
"prikazuje se samo ako se Parlatype pokrene s novim parametrom \\\"--with-"
"asr\\\""

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:145
msgid "Fix internationalization: Some translations were not shown"
msgstr "Ispravak internacionalizacije: Neki prijevodi se nisu prikazivali"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:147
msgid ""
"Translation updates for Arabic, British English, Czech, Dutch, German, "
"Polish and Spanish"
msgstr ""
"Aktualizirani prijevodi za arapski, britanski engleski, češki, nizozemski, "
"njemački, poljski i španjolski"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:154
msgid "This is a major release with some new features."
msgstr "Ovo je glavno izdanje s nekim novim funkcijama."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:157
msgid "Automatic speech recognition with CMU Sphinx"
msgstr "Automatsko prepoznavanje govora sa CMU Sphinx"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:159
msgid "Design changes, including removal of application menu"
msgstr "Promjene u dizajnu, uključujući uklanjanje izbornika aplikacije"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:161
msgid "Custom timestamps"
msgstr "Prilagođene vremenske oznake"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:163
msgid ""
"Translation updates for Brazilian Portuguese, British English, Czech, "
"German, Japanese, Lithuanian and Polish"
msgstr ""
"Aktualizirani prijevodi za brazilski portugalski, britanski engleski, češki, "
"njemački, japanski, litavski i poljski"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:170
msgid "This is a minor maintenance release."
msgstr "Ovo je manje izdanje održavanja."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:173
msgid "Animate scrolling when using keybindings"
msgstr "Animira pomicanje prilikom korištenja tipkovničkih prečaca"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:175
msgid "Change desktop entry category to Audio/Video instead of Utilities"
msgstr ""
"Promijenjena kategorija unosa na radnoj površini u Audio/Video umjesto "
"Utilities"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:177
msgid "Translation updates for French"
msgstr "Aktualiziran prijevod za francuski"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:184
msgid "This release contains a number of bug fixes and minor improvements."
msgstr "Ovo izdanje sadrži niz ispravaka grešaka i poneka poboljšanja."

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:187
msgid "Progress Dialog has now a countdown timer (estimated time left)"
msgstr ""
"Dijalog „Napredak“ sada sadrži timer za odbrojavanje (procijenjeno preostalo "
"vrijeme)"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:189
msgid "Increase max. possible speed to 2.0"
msgstr "Maksimalna moguća brzina povećana na 2.0"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:191
msgid ""
"New keyboard shortcuts for Play/Pause (Ctrl + Space), Jump back (Ctrl + "
"Left), Jump forward (Ctrl + Right)"
msgstr ""
"Novi tipkovni prečaci za „Pokreni/Zaustavi“ (Ctrl + razmaknica), „Skoči "
"natrag“ (Ctrl + strelica lijevo), „Skoči naprijed“ (Ctrl + strelica desno)"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:193
msgid "Scrolling now also possible with vertical scrollbar"
msgstr "Pomicanje je sada moguće i s okomitom trakom za pomicanje"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:195
msgid "Various fixes for waveform and cursor display"
msgstr "Razni ispravci za prikaz valnog oblika zvuka i kursora"

#. Translators: This has very low priority, it's the description for an old release.
#: data/parlatype.metainfo.xml.in:197
msgid ""
"Translation updates for Arabic, British English, Catalan, German, Finnish, "
"French, Japanese, Lithuanian, Polish, Spanish and Swedish"
msgstr ""
"Aktualizirani prijevodi za arapski, britanski engleski, katalonski, "
"njemački, finski, francuski, japanski, litvanski, poljski, španjolski i "
"švedski"

